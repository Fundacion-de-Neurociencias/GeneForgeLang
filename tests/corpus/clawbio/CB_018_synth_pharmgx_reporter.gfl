# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_018
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: pharmacogenomics_pipeline
  type: analysis
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "vcf"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["BRCA2", "APOE", "KRAS", "EGFR", "TPMT"]
    cpic_level_filter: ["D", "B", "A"]
