# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_053
  source_skill: clawbio/pathway-enricher
  domain: functional-genomics

analyze:
  strategy: metagenomics_analysis
  data:
    genes: "de_genes.txt"
  params:
    databases: ["GO_Biological_Process", "Reactome"]
    organism: "mouse"
    fdr_threshold: 0.125
