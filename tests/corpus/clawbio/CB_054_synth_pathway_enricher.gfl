# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_054
  source_skill: clawbio/pathway-enricher
  domain: functional-genomics

analyze:
  strategy: population_genetics
  data:
    genes: "de_genes.txt"
  params:
    databases: ["ClinVar", "Reactome"]
    organism: "zebrafish"
    fdr_threshold: 0.14
