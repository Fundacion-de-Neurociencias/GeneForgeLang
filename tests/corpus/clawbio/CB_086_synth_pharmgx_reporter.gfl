# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_086
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_gwas_lookup
  type: metagenomics
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "23andme_v5"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["DPYD", "BRAF"]
    cpic_level_filter: ["D"]
