# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_067
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_gwas_lookup
  type: sequencing
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "vcf"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["KRAS", "TPMT", "BRCA2", "BRAF", "APOE"]
    cpic_level_filter: ["A", "B", "C"]
