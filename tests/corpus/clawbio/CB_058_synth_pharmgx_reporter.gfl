# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_058
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_pharmgx
  type: simulation
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "vcf"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["EGFR", "APOE"]
    cpic_level_filter: ["B", "A", "C"]
