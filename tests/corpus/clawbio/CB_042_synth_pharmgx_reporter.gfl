# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_042
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_metagenomics_profiler
  type: metagenomics
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "23andme_v5"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["CYP2D6", "BRAF", "BRCA2", "KRAS"]
    cpic_level_filter: ["C", "B"]
