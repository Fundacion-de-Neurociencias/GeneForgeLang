# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_063
  source_skill: clawbio/pathway-enricher
  domain: functional-genomics

analyze:
  strategy: variant
  data:
    genes: "de_genes.txt"
  params:
    databases: ["Reactome", "ClinVar", "GO_Biological_Process"]
    organism: "human"
    fdr_threshold: 0.146
