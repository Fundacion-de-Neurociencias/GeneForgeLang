# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_091
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_pharmgx
  type: metagenomics
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "23andme_v5"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["CYP2D6", "BRCA2", "BRCA1", "EGFR"]
    cpic_level_filter: ["A", "C", "D"]
