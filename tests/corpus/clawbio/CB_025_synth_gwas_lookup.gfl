# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_025
  source_skill: clawbio/gwas-lookup
  domain: population-genomics

experiment:
  tool: clawbio_pharmgx
  type: analysis
  contract:
    inputs:
      variants:
        type: TEXT
        attributes:
          format: "rsid_list"
    outputs:
      gwas_report:
        type: JSON
  params:
    rsids: ["rs123", "rs789", "rs456"]
    databases: ["WikiPathways"]
    p_value_threshold: 4.9e-05
