# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_068
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_pharmgx
  type: sequencing
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "vcf"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["CYP2D6", "DPYD"]
    cpic_level_filter: ["D", "C", "A"]
