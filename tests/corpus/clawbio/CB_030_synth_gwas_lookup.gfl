# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_030
  source_skill: clawbio/gwas-lookup
  domain: population-genomics

experiment:
  tool: clawbio_metagenomics_profiler
  type: analysis
  contract:
    inputs:
      variants:
        type: TEXT
        attributes:
          format: "rsid_list"
    outputs:
      gwas_report:
        type: JSON
  params:
    rsids: ["rs222", "rs789"]
    databases: ["KEGG"]
    p_value_threshold: 4.4e-06
