# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_046
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_metagenomics_profiler
  type: simulation
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "23andme_v5"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["BRAF", "TPMT", "BRCA1", "CYP2D6"]
    cpic_level_filter: ["B"]
