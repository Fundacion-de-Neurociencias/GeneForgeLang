# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_080
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_pharmgx
  type: simulation
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "myheritage"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["BRAF", "APOE", "TPMT"]
    cpic_level_filter: ["B", "D"]
