# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_035
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_pharmgx
  type: simulation
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "23andme_v5"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["BRCA1", "DPYD"]
    cpic_level_filter: ["B", "A", "C"]
