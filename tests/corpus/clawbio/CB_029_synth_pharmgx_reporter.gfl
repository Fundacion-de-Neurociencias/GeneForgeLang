# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_029
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_metagenomics_profiler
  type: simulation
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "myheritage"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["KRAS", "BRAF", "APOE", "TPMT", "CYP2D6"]
    cpic_level_filter: ["A"]
