# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_069
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_metagenomics_profiler
  type: simulation
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "vcf"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["CYP2D6", "DPYD", "TPMT", "APOE", "BRAF"]
    cpic_level_filter: ["C", "A", "D"]
