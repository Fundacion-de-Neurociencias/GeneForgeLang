# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_043
  source_skill: clawbio/gwas-lookup
  domain: population-genomics

experiment:
  tool: pharmacogenomics_pipeline
  type: analysis
  contract:
    inputs:
      variants:
        type: TEXT
        attributes:
          format: "rsid_list"
    outputs:
      gwas_report:
        type: JSON
  params:
    rsids: ["rs111", "rs456", "rs789", "rs222"]
    databases: ["WikiPathways"]
    p_value_threshold: 3.1e-05
