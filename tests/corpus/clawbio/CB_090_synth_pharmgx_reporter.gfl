# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_090
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_gwas_lookup
  type: analysis
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "ancestrydna"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["BRCA1", "APOE", "DPYD", "TPMT", "BRCA2"]
    cpic_level_filter: ["B", "D"]
