# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_048
  source_skill: clawbio/pathway-enricher
  domain: functional-genomics

analyze:
  strategy: population_genetics
  data:
    genes: "de_genes.txt"
  params:
    databases: ["Reactome", "WikiPathways"]
    organism: "zebrafish"
    fdr_threshold: 0.024
