# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_089
  source_skill: clawbio/scrna-orchestrator
  domain: single-cell

guided_discovery:
  data: "cells.h5ad"
  design_params:
    space: "continuous"
    candidates_per_cycle: 5
  active_learning_params:
    strategy: "uncertainty"
  budget:
    max_cycles: 100
  output: "results"
  agents:
    - role: "qc_analyst"
      prompt: "Filter cells with > 18% mitochondrial reads and < 682 genes."
    - role: "clustering_analyst"
      prompt: "Perform louvain clustering with resolution 1.12."
