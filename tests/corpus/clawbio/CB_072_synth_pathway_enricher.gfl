# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_072
  source_skill: clawbio/pathway-enricher
  domain: functional-genomics

analyze:
  strategy: functional
  data:
    genes: "de_genes.txt"
  params:
    databases: ["WikiPathways", "GWAS_Catalog"]
    organism: "mouse"
    fdr_threshold: 0.082
