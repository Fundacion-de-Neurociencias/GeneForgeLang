# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_084
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: pharmacogenomics_pipeline
  type: metagenomics
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "ancestrydna"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["APOE", "BRAF", "KRAS", "BRCA1", "DPYD"]
    cpic_level_filter: ["A", "D", "B"]
