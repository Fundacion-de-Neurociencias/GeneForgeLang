# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_040
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_metagenomics_profiler
  type: metagenomics
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "ancestrydna"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["BRCA1", "DPYD", "TPMT", "BRAF", "BRCA2"]
    cpic_level_filter: ["A", "B", "D"]
