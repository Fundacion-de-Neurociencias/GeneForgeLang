# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_036
  source_skill: clawbio/pathway-enricher
  domain: functional-genomics

analyze:
  strategy: population_genetics
  data:
    genes: "de_genes.txt"
  params:
    databases: ["Reactome", "GWAS_Catalog"]
    organism: "rat"
    fdr_threshold: 0.049
