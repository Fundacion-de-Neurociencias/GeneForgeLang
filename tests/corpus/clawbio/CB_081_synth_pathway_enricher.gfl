# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_081
  source_skill: clawbio/pathway-enricher
  domain: functional-genomics

analyze:
  strategy: population_genetics
  data:
    genes: "de_genes.txt"
  params:
    databases: ["WikiPathways", "GWAS_Catalog", "ClinVar"]
    organism: "human"
    fdr_threshold: 0.154
