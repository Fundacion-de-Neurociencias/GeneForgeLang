# GFL Stress Test Fixture
metadata:
  experiment_id: CB_STRESS_074
  source_skill: clawbio/pharmgx-reporter
  domain: pharmacogenomics

experiment:
  tool: clawbio_pharmgx
  type: sequencing
  contract:
    inputs:
      raw_genome:
        type: TEXT
        attributes:
          format: "ancestrydna"
    outputs:
      pharmacogenomic_report:
        type: JSON
  params:
    genes: ["BRAF", "DPYD", "BRCA2", "TPMT"]
    cpic_level_filter: ["D", "A", "B"]
